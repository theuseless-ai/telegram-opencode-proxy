# Copy to .env (gitignored) and fill in. compose reads this automatically.

# Telegram bot token (from @BotFather). Required.
TELOXIDE_TOKEN=123456:replace-with-your-bot-token

# API key for your LAN LLM, if it requires one (referenced as {env:LLM_LAN_KEY}
# in opencode.json). Leave empty for keyless local servers.
LLM_LAN_KEY=

# External host folder holding each slot's workspace (bind-mounted into both the
# opencode container and the proxy). Must be under a path Colima shares into the
# VM (your home dir is shared by default).
WS_ROOT=/Users/you/agent/ws

# Proxy log level.
RUST_LOG=info
